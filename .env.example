# Supabase (required in production; mock data is used locally without these)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare Turnstile (bot gate on /upload). Optional locally - if the
# site key is missing the widget is skipped; if the secret is missing the
# server action won't verify tokens. Set both in production.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET=

# Server-only secret used to salt the IP+UA fingerprint for vote/report
# idempotency. Set to any random string in production.
FINGERPRINT_SECRET=change-me-to-a-random-string
